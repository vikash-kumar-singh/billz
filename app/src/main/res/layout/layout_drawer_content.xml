<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Part -->
        <include layout="@layout/nav_header_reports" />

        <!-- Menu Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Section: MANAGEMENT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="MANAGEMENT"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Help Chat -->
            <LinearLayout
                android:id="@+id/nav_help_chat"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_help_chat"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_help_chat"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Inventory Management -->
            <LinearLayout
                android:id="@+id/nav_inventory"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_nav_items"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_inventory"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/textSidebarInventoryCount"
                    style="@style/NavBadgeStyle"
                    android:text="327" />
            </LinearLayout>

            <!-- Add Expense -->
            <LinearLayout
                android:id="@+id/nav_add_expense"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_add"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_add_expense"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Receipts -->
            <LinearLayout
                android:id="@+id/nav_receipts"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_receipts"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Customers Management -->
            <LinearLayout
                android:id="@+id/nav_customers"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_customers"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/textSidebarCustomerCount"
                    style="@style/NavBadgeStyle"
                    android:text="470" />
            </LinearLayout>

            <!-- Staff Management -->
            <LinearLayout
                android:id="@+id/nav_staff"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_staff"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
                <TextView
                    style="@style/NavBadgeStyle"
                    android:text="0" />
            </LinearLayout>

            <!-- ShopFront -->
            <LinearLayout
                android:id="@+id/nav_shopfront"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_grid_view"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_shopfront"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
                <TextView
                    style="@style/NavBadgeStyle"
                    android:text="0" />
            </LinearLayout>

            <!-- Refer App -->
            <LinearLayout
                android:id="@+id/nav_refer"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_reports_share"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_refer"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Returned Receipt -->
            <LinearLayout
                android:id="@+id/nav_returned_receipt"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_input_get"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_returned_receipt"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Web Back Office -->
            <LinearLayout
                android:id="@+id/nav_web_office"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_mapmode"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_web_office"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Feedback -->
            <LinearLayout
                android:id="@+id/nav_feedback"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_directions"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_feedback"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Buy Printer -->
            <LinearLayout
                android:id="@+id/nav_buy_printer"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_buy_printer"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
                <TextView
                    style="@style/NavBadgeStyle"
                    android:backgroundTint="#10B981"
                    android:text="New" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#F1F5F9" />

            <!-- Section: Other apps -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="Other apps"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Connect Kitchen display App -->
            <LinearLayout
                android:id="@+id/nav_connect_kitchen"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_call"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_connect_kitchen"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#F1F5F9" />

            <!-- Section: Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:text="Settings"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Language -->
            <LinearLayout
                android:id="@+id/nav_language"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_sort_alphabetically"
                    app:tint="#3F51B5" />
                <TextView
                    android:id="@+id/textLanguageName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="Language - English"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Weighing Machine -->
            <LinearLayout
                android:id="@+id/nav_weighing_machine"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_weighing_machine"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
                <TextView
                    style="@style/NavBadgeStyle"
                    android:backgroundTint="#10B981"
                    android:text="New" />
            </LinearLayout>

            <!-- Receipt Settings -->
            <LinearLayout
                android:id="@+id/nav_receipt_settings"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_receipt_settings"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Business Settings -->
            <LinearLayout
                android:id="@+id/nav_business_settings"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_business_settings"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Printer Setup -->
            <LinearLayout
                android:id="@+id/nav_printer_setup"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_preferences"
                    app:tint="#3F51B5" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_printer_setup"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
                <TextView
                    style="@style/NavBadgeStyle"
                    android:text="3" />
            </LinearLayout>

            <!-- Logout -->
            <LinearLayout
                android:id="@+id/nav_logout"
                style="@style/NavMenuItemStyle">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="#EF4444" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:text="@string/nav_logout"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
