<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".SalarySlipActivity">

    <LinearLayout
        android:id="@+id/toolbarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarSalary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:navigationIcon="@drawable/ic_reports_back"
            app:navigationIconTint="#3F51B5"
            app:title="Vinit"
            app:titleTextColor="#3F51B5">

            <LinearLayout
                android:id="@+id/layoutDateRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#3F51B5" />

                <TextView
                    android:id="@+id/textDateRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="17 Apr 2026 to 16 May 2026"
                    android:textColor="@color/black"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutSummary"
        app:layout_constraintTop_toBottomOf="@id/toolbarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Missing Salary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="4dp"
                app:cardElevation="1dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Staff salary missing"
                        android:textColor="@color/black"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddSalary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:backgroundTint="#66BB6A"
                        android:text="Add Salary"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="4dp" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Daily Attendance List (Mockup using LinearLayout for now, usually a RecyclerView) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="4dp"
                app:cardElevation="1dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/layoutAttendanceList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Example items will be added programmatically or as static mockup -->
                    <include layout="@layout/item_salary_day" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                    <include layout="@layout/item_salary_day" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                    <include layout="@layout/item_salary_day" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                    <include layout="@layout/item_salary_day" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                    <include layout="@layout/item_salary_day" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                    <include layout="@layout/item_salary_day" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                    <include layout="@layout/item_salary_day" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" />
                    <include layout="@layout/item_salary_day" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Salary Summary Footer -->
    <LinearLayout
        android:id="@+id/layoutSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/textBaseSalaryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Base Salary (0 days)"
                android:textColor="@color/black"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/textBaseSalaryValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="₹0"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/textAdditions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="+ ADDITIONS"
            android:textColor="#4CAF50"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <TextView
                android:id="@+id/textDeductions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="- DEDUCTIONS"
                android:textColor="#F44336"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="end"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textTotalSalary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="₹0"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </RelativeLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerateSlip"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#66BB6A"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="GENERATE SALARY SLIP"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="4dp" />
    </LinearLayout>

    <!-- Error Notification Container -->
    <FrameLayout
        android:id="@+id/notificationContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layoutSummary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <include layout="@layout/layout_salary_error_notification" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>