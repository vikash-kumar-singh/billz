<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".BusinessSettingsActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarBusinessSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_chevron_left"
        app:navigationIconTint="@color/colorPrimary"
        app:title="@string/business_settings_title"
        app:titleTextColor="@color/colorPrimary">

        <ImageView
            android:id="@+id/imageHelp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_help"
            app:tint="@color/colorPrimary" />
    </com.google.android.material.appbar.MaterialToolbar>

    <View
        android:id="@+id/toolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/toolbarBusinessSettings" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Receipt ID Prefix -->
            <LinearLayout
                android:id="@+id/itemReceiptIdPrefix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/receipt_id_prefix"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textReceiptIdPrefixValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/receipt_id_prefix_value"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Tax Settings -->
            <LinearLayout
                android:id="@+id/itemTaxSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tax_settings"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textTaxSettingsDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tax_settings_desc"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Discount Settings -->
            <LinearLayout
                android:id="@+id/itemDiscountSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/discount_settings"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textDiscountSettingsDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/discount_settings_desc"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Round Off -->
            <RelativeLayout
                android:id="@+id/itemRoundOff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchRoundOff"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/round_off"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/round_off_desc"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchRoundOff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/colorPrimary"
                    app:trackTint="@color/colorPrimaryLight" />
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Table Management -->
            <RelativeLayout
                android:id="@+id/itemTableManagement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchTableManagement"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/table_management"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/table_management_desc"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchTableManagement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/colorPrimary"
                    app:trackTint="@color/colorPrimaryLight" />
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Inventory Health Score -->
            <RelativeLayout
                android:id="@+id/itemInventoryHealth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/switchInventoryHealth"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/inventory_health_score"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/inventory_health_score_desc"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchInventoryHealth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="@color/colorPrimary"
                    app:trackTint="@color/colorPrimaryLight" />
            </RelativeLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- PaymentMode Settings -->
            <LinearLayout
                android:id="@+id/itemPaymentModeSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_mode_settings"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_mode_settings_desc"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Delivery Fee Settings -->
            <LinearLayout
                android:id="@+id/itemDeliveryFeeSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/delivery_fee_settings"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dash"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Packing Fee Settings -->
            <LinearLayout
                android:id="@+id/itemPackingFeeSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/packing_fee_settings"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_dash"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Service Fee Settings -->
            <LinearLayout
                android:id="@+id/itemServiceFeeSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_fee_settings"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textServiceFeeSettingsDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_fee_settings_desc"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Others Fee Settings -->
            <LinearLayout
                android:id="@+id/itemOtherFeeSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/others_fee_settings"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/textOtherFeeSettingsDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/others_fee_settings_desc"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Delete Business or Reset -->
            <LinearLayout
                android:id="@+id/itemDeleteReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/delete_business_reset"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/delete_business_reset_desc"
                    android:textColor="#64748B"
                    android:textSize="13sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
