<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Custom Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#3F51B5"
            android:minHeight="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_chevron_left"
            app:navigationIconTint="@color/white">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:paddingEnd="16dp">

                <ImageView
                    android:id="@+id/imgActionShare"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="12dp"
                    android:src="@drawable/ic_reports_share"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/imgActionMessage"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="12dp"
                    android:src="@drawable/ic_reports_message"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/imgActionUpload"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="12dp"
                    android:src="@android:drawable/ic_menu_upload"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/btnDownload"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="12dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/imgActionPrint"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginHorizontal="12dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/white" />

            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Top Action Buttons -->
        <LinearLayout
            android:id="@+id/layoutActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:padding="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReturn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:backgroundTint="#3F51B5"
                android:padding="0dp"
                android:text="RETURN"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:backgroundTint="#EF4444"
                android:padding="0dp"
                android:text="DELETE"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:backgroundTint="#3F51B5"
                android:padding="0dp"
                android:text="EDIT"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="2dp" />
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.cardview.widget.CardView
                android:id="@+id/invoiceCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="2dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/textInvoiceHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="* Invoice *"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textReturnedBy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp"
                        android:text="Returned by Business Name"
                        android:textColor="#EF4444"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/imgBusinessLogo"
                        android:layout_width="140dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_nav_reports"
                        android:visibility="visible" />

                    <TextView
                        android:id="@+id/textBusinessName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:text="BUSINESS NAME"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textBusinessAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="Business Address"
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/textBusinessTaxNo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/textBusinessWebsite"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/textBusinessPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="24dp"
                        android:background="#E2E8F0" />

                    <TextView
                        android:id="@+id/textCustomerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:text="Rajesh"
                        android:textColor="#64748B"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textReceiptNo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="48dp"
                        android:text="Receipt# NC-2924"
                        android:textColor="#334155"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Date : 06 Jun 2026 - 7:53 PM"
                        android:textColor="#334155"
                        android:textSize="14sp" />

                    <!-- Payment Mode Table -->
                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:stretchColumns="0">

                        <TableRow
                            android:background="#F8FAFC"
                            android:paddingVertical="8dp">

                            <TextView
                                android:paddingHorizontal="4dp"
                                android:text="P Mode"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />

                            <TextView
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:text="I#"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />

                            <TextView
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:text="U#"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />

                            <TextView
                                android:gravity="end"
                                android:paddingHorizontal="4dp"
                                android:text="Amount"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </TableRow>

                        <TableRow android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/textPMode"
                                android:paddingHorizontal="4dp"
                                android:text="Cash"
                                android:textColor="#334155" />

                            <TextView
                                android:id="@+id/textICount"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:text="1"
                                android:textColor="#334155" />

                            <TextView
                                android:id="@+id/textUCount"
                                android:gravity="center"
                                android:paddingHorizontal="16dp"
                                android:text="2"
                                android:textColor="#334155" />

                            <TextView
                                android:id="@+id/textTotalTable"
                                android:gravity="end"
                                android:paddingHorizontal="4dp"
                                android:text="₹252.000"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </TableRow>
                    </TableLayout>

                    <!-- Items Table -->
                    <TableLayout
                        android:id="@+id/tableItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:stretchColumns="0">

                        <TableRow
                            android:background="#F8FAFC"
                            android:paddingVertical="8dp">

                            <TextView
                                android:paddingHorizontal="4dp"
                                android:text="Name"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />

                            <TextView
                                android:gravity="end"
                                android:paddingLeft="32dp"
                                android:paddingRight="16dp"
                                android:text="Price"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />

                            <TextView
                                android:gravity="center"
                                android:paddingHorizontal="24dp"
                                android:text="Qty"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />

                            <TextView
                                android:gravity="end"
                                android:paddingLeft="16dp"
                                android:paddingRight="4dp"
                                android:text="Total"
                                android:textColor="#1E293B"
                                android:textStyle="bold" />
                        </TableRow>
                        <!-- Rows added dynamically -->
                    </TableLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="32dp"
                        android:background="#334155" />

                    <!-- Summary -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtotal"
                            android:textColor="#64748B" />

                        <TextView
                            android:id="@+id/textSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹252.000"
                            android:textColor="#334155" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Grand Total"
                            android:textColor="#1E293B"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textGrandTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹252.000"
                            android:textColor="#1E293B"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textThankYou"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="32dp"
                        android:text="Thank You! Visit again!"
                        android:textColor="#64748B"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp"
                        android:text="Powered By Zobaze"
                        android:textColor="#94A3B8"
                        android:textSize="12sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewSale"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="12dp"
            android:backgroundTint="#66BB6A"
            android:text="New Sale"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:cornerRadius="4dp" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>