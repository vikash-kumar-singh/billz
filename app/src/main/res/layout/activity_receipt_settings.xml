<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Top Bar -->
    <FrameLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/reports_tab_selected">

        <RelativeLayout
            android:id="@+id/topBarContent"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/imageBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white"
                android:contentDescription="@string/reports_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/receipt_settings_title"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <LinearLayout
                android:id="@+id/layoutSave"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/save"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
            </LinearLayout>
        </RelativeLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Main Business Info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Business Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/business_name_label"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/etBusinessName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/test_business_name"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="textPersonName" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginBottom="16dp" />

                    <!-- Business Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/business_email_label"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/etBusinessEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/email_address"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="textEmailAddress" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginBottom="16dp" />

                    <!-- Phone Number -->
                    <EditText
                        android:id="@+id/etPhoneNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/phone_number_hint"
                        android:inputType="phone"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />
                    <CheckBox
                        android:id="@+id/cbShowPhoneNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/show_in_receipt"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Business Address -->
                    <EditText
                        android:id="@+id/etBusinessAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/business_address_label"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="textPostalAddress" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />
                    <CheckBox
                        android:id="@+id/cbShowBusinessAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/show_in_receipt"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Tax no. and Title -->
                    <EditText
                        android:id="@+id/etTaxNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/tax_no_label"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="text" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />
                    <CheckBox
                        android:id="@+id/cbShowTaxNo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/show_in_receipt"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Website -->
                    <EditText
                        android:id="@+id/etWebsite"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/website_label"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="textUri" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />
                    <CheckBox
                        android:id="@+id/cbShowWebsite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/show_in_receipt"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Receipt title (optional) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/receipt_title_optional"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="12sp" />
                    <EditText
                        android:id="@+id/etReceiptTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/receipt_title_hint"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="text" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Receipt Options (Logo) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/receipt_options_title"
                        android:textColor="@color/reports_tab_selected"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/business_logo_label"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp" />

                    <FrameLayout
                        android:id="@+id/layoutAddLogo"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@color/reports_chip_background"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:id="@+id/ivBusinessLogo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerInside"
                            android:padding="8dp"
                            android:contentDescription="@string/business_logo_label" />
                        <ImageView
                            android:id="@+id/ivAddIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_input_add"
                            app:tint="@color/black"
                            android:contentDescription="@string/next" />
                    </FrameLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" />

                    <CheckBox
                        android:id="@+id/cbShowLogo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="@string/show_in_receipt_beta"
                        android:textColor="@color/black"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/logo_disclaimer"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Receipt Options (Toggles) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/receipt_options_title"
                        android:textColor="@color/reports_tab_selected"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <!-- List Price -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchListPrice" android:layout_centerVertical="true" android:text="@string/show_list_price_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchListPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Rate in Receipt -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchShowRate" android:layout_centerVertical="true" android:text="@string/show_rate_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchShowRate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp" />

                    <!-- Total Money Saved -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchTotalSaved" android:text="@string/show_total_saved_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchTotalSaved" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/show_total_saved_desc"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="48dp" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="16dp" />

                    <!-- Cashier Name -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchCashierName" android:layout_centerVertical="true" android:text="@string/show_cashier_name_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchCashierName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp" />

                    <!-- Customer Phone -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchCustomerPhone" android:layout_centerVertical="true" android:text="@string/show_customer_phone_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchCustomerPhone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Customer Address -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchCustomerAddress" android:layout_centerVertical="true" android:text="@string/show_customer_address_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchCustomerAddress" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp" />

                    <!-- Thank You Note -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/thank_you_note_label" android:textColor="@color/reports_text_secondary" android:textSize="11sp" />
                    <EditText
                        android:id="@+id/etThankYouNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/thank_you_note_hint"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="text" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginBottom="16dp" />

                    <!-- Use App Language -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchAppLang" android:layout_centerVertical="true" android:text="@string/use_app_lang_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchAppLang" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Total Item Count -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchTotalItem" android:layout_centerVertical="true" android:text="@string/show_total_item_count_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchTotalItem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Change Return -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchChangeReturn" android:layout_centerVertical="true" android:text="@string/show_change_return_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchChangeReturn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Payment Details -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchPaymentDetails" android:layout_centerVertical="true" android:text="@string/show_payment_details_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchPaymentDetails" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Powered By -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_toStartOf="@id/switchPoweredBy" android:layout_centerVertical="true" android:text="@string/show_powered_by_label" android:textColor="@color/black" android:textSize="14sp" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchPoweredBy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <!-- Order items by -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/order_items_by_label" android:textColor="@color/black" android:textSize="16sp" android:layout_marginBottom="8dp" />
                    <RadioGroup
                        android:id="@+id/rgOrderItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton android:id="@+id/rbOrderName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/order_by_name" android:textColor="@color/black" />
                        <RadioButton android:id="@+id/rbOrderAdded" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/order_by_added" android:textColor="@color/black" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 4: Message Template -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/template_title"
                        android:textColor="@color/reports_tab_selected"
                        android:textSize="18sp"
                        android:textStyle="bold" android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/include_in_message"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="11sp" />
                    <EditText
                        android:id="@+id/etMessageTemplate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/template_default"
                        android:paddingVertical="8dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/reports_text_secondary"
                        android:textSize="16sp"
                        android:importantForAutofill="no"
                        android:inputType="textLongMessage" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/template_desc"
                        android:textColor="@color/reports_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 5: Select WhatsApp Share App -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/whatsapp_app_title"
                        android:textColor="@color/reports_tab_selected"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <RadioGroup
                        android:id="@+id/rgWhatsappApp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton
                            android:id="@+id/rbWhatsapp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/whatsapp"
                            android:textColor="@color/black" />
                        <RadioButton
                            android:id="@+id/rbWhatsappBusiness"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/whatsapp_business"
                            android:textColor="@color/black" />
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
