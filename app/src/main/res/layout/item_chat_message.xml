<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="8dp">

    <!-- Bot Message -->
    <LinearLayout
        android:id="@+id/layoutBot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="48dp"
        android:background="@drawable/bg_chat_bubble_bot"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <TextView
            android:id="@+id/textBotMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi there! I'm your Billz assistant."
            android:textColor="#1E293B"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <!-- User Message -->
    <LinearLayout
        android:id="@+id/layoutUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="48dp"
        android:background="@drawable/bg_chat_bubble_user"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/textUserMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello bot"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <!-- WhatsApp Link -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWhatsappChat"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginTop="8dp"
        android:backgroundTint="#DCFCE7"
        android:text="@string/chatbot_whatsapp"
        android:textColor="#166534"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_call_support"
        app:iconTint="#166534" />

</LinearLayout>
