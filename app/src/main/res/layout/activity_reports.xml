<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reportsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/reports_background"
    tools:context=".ReportsActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="@dimen/reports_screen_padding_horizontal" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="@dimen/reports_screen_padding_horizontal" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarReports"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/reports_surface"
        android:elevation="0dp"
        android:minHeight="@dimen/reports_toolbar_height"
        app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineStart"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_reports_back"
        app:title="@string/reports_title"
        app:titleCentered="false"
        app:titleTextColor="@color/reports_text_primary" />

    <LinearLayout
        android:id="@+id/dateSelectorRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_reports_date_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/reports_date_row_padding_horizontal"
        android:paddingTop="@dimen/reports_date_row_padding_vertical"
        android:paddingEnd="@dimen/reports_date_row_padding_horizontal"
        android:paddingBottom="@dimen/reports_date_row_padding_vertical"
        android:layout_marginTop="@dimen/reports_date_row_margin_top"
        app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineStart"
        app:layout_constraintTop_toBottomOf="@id/toolbarReports">

        <ImageView
            android:id="@+id/imageCalendar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/reports_calendar"
            android:src="@drawable/ic_reports_calendar" />

        <TextView
            android:id="@+id/textDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/reports_date_today"
            android:textColor="@color/reports_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/emptyStateContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/reports_empty_section_horizontal"
        android:paddingEnd="@dimen/reports_empty_section_horizontal"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="@id/guidelineEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineStart"
        app:layout_constraintTop_toBottomOf="@id/dateSelectorRow"
        app:layout_constraintVertical_bias="0.42">

        <ImageView
            android:id="@+id/imageEmptyState"
            android:layout_width="@dimen/reports_empty_icon_size"
            android:layout_height="@dimen/reports_empty_icon_size"
            android:contentDescription="@string/reports_empty_message"
            android:src="@drawable/ic_reports_empty_state" />

        <TextView
            android:id="@+id/textEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/reports_empty_text_margin_top"
            android:gravity="center"
            android:maxWidth="@dimen/reports_empty_state_max_width"
            android:text="@string/reports_empty_message"
            android:textAlignment="center"
            android:textColor="@color/reports_text_secondary"
            android:textSize="17sp"
            tools:ignore="TextViewEdits" />
    </LinearLayout>

    <TextView
        android:id="@+id/reportsContentPlaceholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reports_content_placeholder"
        android:textColor="@color/reports_text_secondary"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dateSelectorRow" />

    <View
        android:id="@+id/bottomNavDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/reports_divider"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="@dimen/reports_bottom_nav_height"
        android:background="@color/reports_surface"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="@dimen/reports_bottom_nav_padding_top"
        android:paddingBottom="@dimen/reports_bottom_nav_padding_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/tabReports"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_reports_nav_item"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iconReports"
                android:layout_width="@dimen/reports_bottom_nav_icon_size"
                android:layout_height="@dimen/reports_bottom_nav_icon_size"
                android:contentDescription="@string/reports_tab_reports"
                android:src="@drawable/ic_nav_reports"
                android:tint="@color/white" />

            <TextView
                android:id="@+id/labelReports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/reports_tab_reports"
                android:textColor="@color/white"
                android:textSize="@dimen/reports_bottom_nav_label_text"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabToday"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iconToday"
                android:layout_width="@dimen/reports_bottom_nav_icon_size"
                android:layout_height="@dimen/reports_bottom_nav_icon_size"
                android:contentDescription="@string/reports_tab_today"
                android:src="@drawable/ic_nav_today"
                android:tint="@color/reports_tab_unselected" />

            <TextView
                android:id="@+id/labelToday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/reports_tab_today"
                android:textColor="@color/reports_tab_unselected"
                android:textSize="@dimen/reports_bottom_nav_label_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabCounter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iconCounter"
                android:layout_width="@dimen/reports_bottom_nav_icon_size"
                android:layout_height="@dimen/reports_bottom_nav_icon_size"
                android:contentDescription="@string/reports_tab_counter"
                android:src="@drawable/ic_nav_counter"
                android:tint="@color/reports_tab_unselected" />

            <TextView
                android:id="@+id/labelCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/reports_tab_counter"
                android:textColor="@color/reports_tab_unselected"
                android:textSize="@dimen/reports_bottom_nav_label_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabItems"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iconItems"
                android:layout_width="@dimen/reports_bottom_nav_icon_size"
                android:layout_height="@dimen/reports_bottom_nav_icon_size"
                android:contentDescription="@string/reports_tab_items"
                android:src="@drawable/ic_nav_items"
                android:tint="@color/reports_tab_unselected" />

            <TextView
                android:id="@+id/labelItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/reports_tab_items"
                android:textColor="@color/reports_tab_unselected"
                android:textSize="@dimen/reports_bottom_nav_label_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabMore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iconMore"
                android:layout_width="@dimen/reports_bottom_nav_icon_size"
                android:layout_height="@dimen/reports_bottom_nav_icon_size"
                android:contentDescription="@string/reports_tab_more"
                android:src="@drawable/ic_nav_more"
                android:tint="@color/reports_tab_unselected" />

            <TextView
                android:id="@+id/labelMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/reports_tab_more"
                android:textColor="@color/reports_tab_unselected"
                android:textSize="@dimen/reports_bottom_nav_label_text" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
