<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="2dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="0.5dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/textInitial"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_inventory_initial"
            android:backgroundTint="#2563EB"
            android:gravity="center"
            android:text="S"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shamim"
                android:textColor="#334155"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textCustomerMobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="7250297184"
                android:textColor="#64748B"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/badgeOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_customer_badge"
                    android:backgroundTint="#22C55E"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="1 ORDERS"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/badgeTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_customer_badge"
                    android:backgroundTint="#3B82F6"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="ABOUT AN HOUR AGO"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/badgeNew"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_customer_badge"
                    android:backgroundTint="#F59E0B"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="NEW"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
