<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="4dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Variant Name Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVariantImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"
                app:cardMaxElevation="0dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/imgVariant"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#64748B" />
            </com.google.android.material.card.MaterialCardView>

            <EditText
                android:id="@+id/editVariantName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:hint="Enter Variant Name"
                android:textColor="@color/black"
                android:textColorHint="#94A3B8"
                android:textSize="16sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0" />

        <!-- Price Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selling Price*"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/editSellingPriceAdvance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="₹0"
                    android:inputType="numberDecimal"
                    android:textColor="@color/black"
                    android:textColorHint="#94A3B8"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cost Price"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/editCostPriceAdvance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="-"
                    android:inputType="numberDecimal"
                    android:textColor="@color/black"
                    android:textColorHint="#94A3B8"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock Available"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/editStockAdvance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="-"
                    android:inputType="number"
                    android:textColor="@color/black"
                    android:textColorHint="#94A3B8"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0" />

        <!-- Variant Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#BDBDBD" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#BDBDBD" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="#BDBDBD" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="#BDBDBD" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#BDBDBD" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="TAX"
                android:textColor="#BDBDBD"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="#BDBDBD" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginHorizontal="6dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#BDBDBD" />

            <View
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btnMoveUp"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_arrow_drop_up"
                app:tint="#3F51B5" />

            <ImageView
                android:id="@+id/btnMoveDown"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="4dp"
                android:src="@drawable/ic_arrow_drop_down"
                app:tint="#3F51B5" />

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <ImageView
                android:id="@+id/btnRemoveVariant"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#EF4444" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
